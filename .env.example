# Copy to .env and fill in values before running locally.

# Required for the Gemini Flash ReAct agent.
# Free key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Where to store session data (schedule + scores).
#   Local dev:  ./data   (default — auto-created)
#   Azure:      /home/data  (set this in App Service > Configuration > App Settings)
DATA_DIR=./data

# Ports (defaults are fine for local dev)
# FLASK_PORT=5000
# WEBSITES_PORT=8501

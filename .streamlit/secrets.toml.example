# Paste the contents of this file into:
#   Streamlit Community Cloud → your app → Settings → Secrets
#
# Replace the api_key value with your real key.
# Do NOT rename the section headers ([gemini], [app]).

[gemini]
api_key           = "YOUR_GOOGLE_API_KEY_HERE"
model_name        = "gemini-2.0-flash"
temperature       = 0.7
top_p             = 0.95
max_output_tokens = 4096

[app]
data_dir       = "/tmp"     # writable temp dir on Streamlit Cloud
default_rounds = 12
